# AI provider (Groq or another OpenAI-compatible API)
API_KEY=

# Optional Google Custom Search credentials
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# WhatsApp gateway
WHATSAPP_GATEWAY_URL=http://localhost:3000
WHATSAPP_INSTANCE=personal-assistant

# Optional webhook protection. Use the same value in the Go gateway.
WEBHOOK_SECRET=

# Admin numbers separated by commas, using country code and digits only.
ADMIN_NUMBERS=5511999999999

# FastAPI server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=false
